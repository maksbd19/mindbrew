# PostgreSQL
# Local: postgresql+psycopg:// or postgresql:// (auto-normalized to psycopg v3)
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/brewmind

# Production (Supabase on Render): use Session pooler URI (IPv4), NOT Direct connection (IPv6).
# Supabase → Settings → Database → Connection string → Session pooler → URI (port 5432)
# Host looks like: aws-0-[region].pooler.supabase.com
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres

# Nebius Token Factory (OpenAI-compatible)
NEBIUS_API_KEY=your_key_from_tokenfactory.nebius.com
NEBIUS_MODEL=deepseek-ai/DeepSeek-V4-Pro
NEBIUS_BASE_URL=https://api.tokenfactory.nebius.com/v1/

# Use offline mocks when true (no LLM/FBA calls)
BREWMIND_OFFLINE=false

# FBA deps: uv sync --extra fba (cobra, python-libsbml, optlang)

MAX_REVISIONS=5

# Literature retrieval (Lamin/bionty + PubMed + Crossref RAG)
LITERATURE_RETRIEVAL_ENABLED=true
LAMIN_PUBLIC_DBS=laminlabs/cellxgene
LITERATURE_MAX_ONTOLOGY_HITS=5
LITERATURE_MAX_ARTIFACT_HITS=5
LITERATURE_MAX_PUBMED_HITS=8
LITERATURE_MAX_CROSSREF_HITS=5
LITERATURE_CONTEXT_MAX_CHARS=8000

# Live progress heartbeats during long-running graph steps (seconds)
PROGRESS_HEARTBEAT_INTERVAL_SEC=15

# Local dev: web app proxies /api → FastAPI (see web/next.config.js)
API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_API_URL=/api

# Production hybrid deploy:
# - Postgres: Supabase (DATABASE_URL on Render brewmind-api)
# - Migrations: ./scripts/run-migrations.sh (run separately, not on app start)
# - Python API: Render (set NEBIUS_* + DATABASE_URL + CORS_ORIGINS in dashboard)
# - Next.js: Vercel Root Directory=web, API_URL + NEXT_PUBLIC_API_URL = Render API URL
# CORS_ORIGINS=https://your-app.vercel.app

# Optional comma-separated extra CORS origins for direct API access
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
